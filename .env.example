# Suffix for local hostnames. *.localhost is recommended — RFC 6761 reserves
# it for loopback on every OS, so no DNS setup is required.
SUFFIX=docker.localhost

# Tailscale identity (filled by bootstrap.sh from `tailscale ip -4` and
# `tailscale status`). Leave empty to disable cross-machine routing.
TAILSCALE_IP=
MACHINE_NAME=
TAILNET_DOMAIN=

# --- Takeover suffixes (optional) ---
# Comma-separated list of additional hostname suffixes to serve, on top of the
# default *.localhost suffix above. Useful when *.localhost isn't viable on
# this machine (corporate network restrictions, captive portals) or when you
# want URLs that match an alternate runtime's convention (.orb.local for
# OrbStack-style URLs, .colima.local for Colima, etc.). Macs only.
# Empty disables the feature entirely (no dnsmasq, no resolver files).
# See docs/takeover-suffixes.md before enabling.
TAKEOVER_SUFFIXES=
TAKEOVER_DNS_PORT=5300
# Synthesized by bootstrap.sh from TAKEOVER_SUFFIXES; do not edit by hand.
TAKEOVER_ADDRESS_FLAGS=
